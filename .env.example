# ==============================================================================
# BioSense AI: Release Environment Variables Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend Configuration (FastAPI)
# ------------------------------------------------------------------------------
# Comma-separated list of origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-vercel-domain.vercel.app

# ------------------------------------------------------------------------------
# Frontend Configuration (Next.js)
# ------------------------------------------------------------------------------
# URL of the FastAPI backend service (required for client-side API calls)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# Database & External Services (Future Enhancements)
# ------------------------------------------------------------------------------
MONGODB_URI=
GEMINI_API_KEY=
OPENAI_API_KEY=
